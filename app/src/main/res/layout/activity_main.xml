<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="SHAL-1000 릴레이 제어"
        android:textSize="20sp" android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <Button android:id="@+id/connectButton" android:text="연결"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <TextView android:id="@+id/statusView" android:text="상태: 대기"
        android:layout_marginTop="4dp" android:layout_marginBottom="16dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <Button android:id="@+id/relay0Button" android:text="릴레이 0"
        android:textColor="#FFFFFF" android:textStyle="bold"
        android:layout_marginBottom="12dp"
        android:padding="18dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <Button android:id="@+id/relay1Button" android:text="릴레이 1"
        android:textColor="#FFFFFF" android:textStyle="bold"
        android:padding="18dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <TextView android:text="로그" android:layout_marginTop="16dp" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/logView"
        android:fontFamily="monospace" android:textSize="11sp"
        android:layout_width="match_parent" android:layout_height="match_parent"/>
</LinearLayout>
